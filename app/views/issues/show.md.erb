<%= md_text("# ##{@issue.id} #{md_inline(@issue.subject)}") %>

<%= md_text("## #{l(:label_issue)}") %>

- **<%= md_inline(l(:field_project)) %>**: <%= md_text(md_value(@issue.project)) %>
- **<%= md_inline(l(:field_tracker)) %>**: <%= md_text(md_value(@issue.tracker)) %>
- **<%= md_inline(l(:field_status)) %>**: <%= md_text(md_value(@issue.status)) %>
- **<%= md_inline(l(:field_priority)) %>**: <%= md_text(md_value(@issue.priority)) %>
- **<%= md_inline(l(:field_author)) %>**: <%= md_text(md_value(@issue.author)) %>
- **<%= md_inline(l(:field_assigned_to)) %>**: <%= md_text(md_value(@issue.assigned_to)) %>
- **<%= md_inline(l(:field_category)) %>**: <%= md_text(md_value(@issue.category)) %>
- **<%= md_inline(l(:field_fixed_version)) %>**: <%= md_text(md_value(@issue.fixed_version)) %>
- **<%= md_inline(l(:field_start_date)) %>**: <%= md_text(@issue.start_date ? format_date(@issue.start_date) : '-') %>
- **<%= md_inline(l(:field_due_date)) %>**: <%= md_text(@issue.due_date ? format_date(@issue.due_date) : '-') %>
- **<%= md_inline(l(:field_done_ratio)) %>**: <%= md_text("#{@issue.done_ratio}%") %>
- **<%= md_inline(l(:field_estimated_hours)) %>**: <%= md_text(@issue.estimated_hours ? "#{@issue.estimated_hours}h" : '-') %>
- **<%= md_inline(l(:field_created_on)) %>**: <%= md_text(format_time(@issue.created_on)) %>
- **<%= md_inline(l(:field_updated_on)) %>**: <%= md_text(format_time(@issue.updated_on)) %>
- **URL**: <%= md_text(md_issue_url(@issue)) %>
<% @issue.visible_custom_field_values.each do |cfv| -%>
<% next if cfv.value.blank? -%>
- **<%= md_inline(cfv.custom_field.name) %>**: <%= md_text(md_value(cfv.value.is_a?(Array) ? cfv.value.join(', ') : cfv.value)) %>
<% end -%>

<%= md_text("## #{l(:field_description)}") %>

<%= md_text(@issue.description.presence || "_#{l(:label_no_data)}_") %>

<% if @issue.attachments.any? -%>
<%= md_text("## #{l(:label_attachment_plural)}") %>

<% @issue.attachments.each do |attachment| -%>
<%= md_text("- [#{md_inline(attachment.filename)}](#{md_attachment_url(attachment)}) (#{md_filesize(attachment.filesize)}) - #{md_value(attachment.author)}, #{format_time(attachment.created_on)}") %>
<% if attachment.description.present? -%>
  <%= md_text(md_value(attachment.description)) %>
<% end -%>
<% end -%>

<% end -%>
<% if @journals.present? && @journals.any? { |j| j.notes.present? } -%>
<%= md_text("## #{l(:label_comment_plural)}") %>

<% @journals.each do |journal| -%>
<% next if journal.notes.blank? -%>
<%= md_text("### #{format_time(journal.created_on)} #{journal.user}") %>

<%= md_text(journal.notes) %>

<% end -%>
<% end -%>
